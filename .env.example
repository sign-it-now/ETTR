# ─── ETTR Environment Variables ──────────────────────────────────────────────
# Copy this file to .env.local for local development.
# For production (GitHub Pages), add these as GitHub Actions secrets:
#   Repo → Settings → Secrets and variables → Actions → New repository secret
#
# After adding secrets, the build workflow will embed them in the JS bundle.
# New users who open the app will skip the Setup wizard and go straight to Login.
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub (required) ─────────────────────────────────────────────────────────
REACT_APP_GITHUB_REPO=https://github.com/your-org/ETTR
REACT_APP_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
REACT_APP_BRANCH=main

# ── Claude AI (optional — enables rate con scanning) ──────────────────────────
REACT_APP_CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Google Sign-In (optional) ─────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com/
# APIs & Services → Credentials → Create OAuth Client ID (Web application)
# Add your GitHub Pages URL as an Authorized JavaScript origin:
#   https://your-org.github.io
# Add your GitHub Pages URL as an Authorized redirect URI:
#   https://your-org.github.io/ETTR/
REACT_APP_GOOGLE_CLIENT_ID=123456789-xxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Apple Sign-In (optional) ──────────────────────────────────────────────────
# Requires Apple Developer account ($99/yr)
# Create a Services ID at https://developer.apple.com/account/resources/identifiers/
# Enable "Sign In with Apple" and add your GitHub Pages domain.
# The Service ID looks like: com.yourcompany.ettr
REACT_APP_APPLE_SERVICE_ID=com.yourcompany.ettr
